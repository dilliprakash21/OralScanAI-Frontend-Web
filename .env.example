VITE_API_URL=http://your-backend-ip:8090
VITE_ANALYZE_URL=http://your-backend-ip:8090

# SMTP Configuration (Required for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="OralScan AI <your-email@gmail.com>"

ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-3-7-sonnet-20250219
CLAUDE_VALIDATION_ENABLED=true
CLAUDE_MIN_CONFIDENCE=0.75
MIN_IMAGE_SIDE=256
MIN_BLUR_SCORE=80.0
MIN_BRIGHTNESS=35.0
MAX_BRIGHTNESS=220.0
